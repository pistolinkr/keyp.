# Public keys only (safe for Vite client). Never put service_role here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Match Supabase Auth → Bot and abuse protection (hCaptcha or Turnstile site key only).
# VITE_CAPTCHA_PROVIDER=turnstile
# VITE_CAPTCHA_PROVIDER=hcaptcha
# VITE_CAPTCHA_SITE_KEY=your-site-key
# Localhost is disabled by default (to avoid Turnstile domain/protocol issues).
# Set true only when you intentionally test CAPTCHA on localhost.
VITE_CAPTCHA_ENABLE_LOCAL=false

# Backend AI — set on the Node server (pnpm start), Docker `api` service, or Vercel for api/ai/*
# (Ollama must be reachable from that host; not from the browser).
# OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Docker API stack: pnpm docker:ai:up — env is NOT synced from Vercel. On the host running Docker:
#   cp .env.docker.example .env.docker   then edit; or export vars in the shell.
# See .env.docker.example (API container only — never put VITE_* there for Docker to “receive”).
# Docker Compose (optional): OLLAMA_* for `api` is in docker-compose.yml.

# When the SPA is on a different origin than the API (e.g. Vercel → Docker), set on the API server only:
# AI_CORS_ORIGIN=https://your-spa-origin.vercel.app

# Optional — only if AI is on another host (origin only, no /api/ai path). Same Vercel app as SPA: omit entirely.
# VITE_AI_API_BASE_URL=https://your-api-host.example.com

# Local-only (e.g. .env.local). Omit on Vercel — magic-link bypass applies only to this exact email.
# VITE_DEV_USER_EMAIL=local.sys@keyp.product