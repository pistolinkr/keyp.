# Copy to .env.docker or docker.env (both gitignored) for pnpm docker:ai:up
# Only variables the Node API container needs — not VITE_* (Vercel / Vite build only).

# Origins only (no /api/... paths). Several sites: comma-separated, e.g.
# AI_CORS_ORIGIN=https://a.vercel.app,https://www.example.com
AI_CORS_ORIGIN=https://keypproduction.vercel.app
OLLAMA_MODEL=llama3.1:8b

# Optional: HOST_PORT is read by the shell script, not Docker — export or put in .env.docker:
# HOST_PORT=3000
